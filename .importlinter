[importlinter]
root_package = src
include_external_packages = false

# =============================================================================
# ARCHITECTURAL BOUNDARY CONTRACTS — Clinical Data Derivation Engine
#
# Enforces: domain (pure) → agents → engine → verification
# Each layer can only import from layers below it, never above.
#
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN LAYER — Pure Python + Pydantic + networkx + pandas
# The domain layer is the foundation. It must NOT import from any upper layer.
# -----------------------------------------------------------------------------

[importlinter:contract:domain-no-agents]
name = Domain cannot import from Agents
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.agents

[importlinter:contract:domain-no-engine]
name = Domain cannot import from Engine
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.engine

[importlinter:contract:domain-no-verification]
name = Domain cannot import from Verification
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.verification

# -----------------------------------------------------------------------------
# AGENTS LAYER — Depends on domain/ only
# Agents define PydanticAI agent configs + tools. No engine, no persistence.
# -----------------------------------------------------------------------------

[importlinter:contract:agents-no-engine]
name = Agents cannot import from Engine
type = forbidden
source_modules =
    src.agents
forbidden_modules =
    src.engine

[importlinter:contract:agents-no-verification]
name = Agents cannot import from Verification
type = forbidden
source_modules =
    src.agents
forbidden_modules =
    src.verification

# -----------------------------------------------------------------------------
# VERIFICATION LAYER — Depends on domain/ only
# Verification compares coder vs QC outputs. Independent of agents and engine.
# This ensures QC independence — verification doesn't know about agent internals.
# -----------------------------------------------------------------------------

[importlinter:contract:verification-no-agents]
name = Verification cannot import from Agents (QC independence)
type = forbidden
source_modules =
    src.verification
forbidden_modules =
    src.agents

[importlinter:contract:verification-no-engine]
name = Verification cannot import from Engine
type = forbidden
source_modules =
    src.verification
forbidden_modules =
    src.engine

# -----------------------------------------------------------------------------
# ENGINE LAYER — Depends on domain/, agents/, verification/
# Engine orchestrates the workflow. In Phase 4, persistence is injected via DI
# (engine must NOT directly import from persistence).
# -----------------------------------------------------------------------------

# =============================================================================
# PHASE 4 CONTRACTS — activated now that src.persistence and src.audit exist
# =============================================================================

[importlinter:contract:domain-no-persistence]
name = Domain cannot import from Persistence
type = forbidden
source_modules = src.domain
forbidden_modules = src.persistence

[importlinter:contract:domain-no-audit]
name = Domain cannot import from Audit
type = forbidden
source_modules = src.domain
forbidden_modules = src.audit

[importlinter:contract:agents-no-persistence]
name = Agents cannot import from Persistence
type = forbidden
source_modules = src.agents
forbidden_modules = src.persistence

[importlinter:contract:agents-no-audit]
name = Agents cannot import from Audit
type = forbidden
source_modules = src.agents
forbidden_modules = src.audit

[importlinter:contract:engine-no-persistence]
name = Engine cannot import Persistence directly (use DI)
type = forbidden
source_modules = src.engine
forbidden_modules = src.persistence

[importlinter:contract:verification-no-persistence]
name = Verification cannot import from Persistence
type = forbidden
source_modules = src.verification
forbidden_modules = src.persistence

[importlinter:contract:persistence-no-agents]
name = Persistence cannot import from Agents
type = forbidden
source_modules = src.persistence
forbidden_modules = src.agents

[importlinter:contract:persistence-no-engine]
name = Persistence cannot import from Engine
type = forbidden
source_modules = src.persistence
forbidden_modules = src.engine

[importlinter:contract:audit-no-engine]
name = Audit cannot import from Engine
type = forbidden
source_modules = src.audit
forbidden_modules = src.engine

[importlinter:contract:audit-no-persistence]
name = Audit cannot import from Persistence
type = forbidden
source_modules = src.audit
forbidden_modules = src.persistence

[importlinter:contract:audit-no-agents]
name = Audit cannot import from Agents
type = forbidden
source_modules = src.audit
forbidden_modules = src.agents

[importlinter:contract:ui-no-persistence]
name = UI cannot import Persistence directly
type = forbidden
source_modules = src.ui
forbidden_modules = src.persistence
# UI reaches persistence only through factory DI wiring, never directly
ignore_imports =
    src.factory -> src.persistence.database

[importlinter:contract:api-no-ui]
name = API cannot import from UI
type = forbidden
source_modules = src.api
forbidden_modules = src.ui

[importlinter:contract:api-no-persistence]
name = API cannot import from Persistence directly
type = forbidden
source_modules = src.api
forbidden_modules = src.persistence
# ARCHITECTURAL EXCEPTIONS (not violations):
# - app.py: FastAPI lifespan runs init_db() at startup to wire DB session factory.
# - workflow_manager: owns session lifecycle (Repository/Unit-of-Work pattern) —
#   mirrors how a service would own a DBDep chain in a typical FastAPI DI setup.
# - factory: infrastructure wiring (create_pipeline_orchestrator), not business logic.
# Routers MUST NOT import persistence — all router-level access goes through
# WorkflowManager, which is re-verified by the delete_workflow endpoint fix (no
# init_db/Session/WorkflowStateRepository in routers/workflows.py).
ignore_imports =
    src.api.app -> src.persistence.database
    src.api.app -> src.persistence.workflow_state_repo
    src.api.workflow_manager -> src.persistence.database
    src.api.workflow_manager -> src.persistence.workflow_state_repo
    src.api.workflow_manager -> src.factory
    src.api.workflow_lifecycle -> src.persistence.workflow_state_repo
