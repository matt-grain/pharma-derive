---
title: Per-variable derivation detail (inside derive_variables parallel_map)
---
sequenceDiagram
    participant DR as derivation_runner.run_variable
    participant F as query_feedback
    participant QH as query_qc_history
    participant QP as query_patterns
    participant C as Coder Agent
    participant QC as QC Agent
    participant S as Sandbox (execute_code)
    participant V as Comparator
    participant D as Debugger Agent
    participant DAG as DerivationDAG
    participant AT as AuditTrail

    DR->>DR: get_node(variable) + build CoderDeps(df, synthetic_csv, rule)

    Note over DR,QP: LTM read loop (Phase 17.1 — authority hierarchy)
    DR->>F: query_feedback(variable)
    F-->>DR: recent human reviewer decisions (STRONGEST signal)
    DR->>QH: query_qc_history(variable)
    QH-->>DR: prior coder/QC verdict pairs with debugger picks
    DR->>QP: query_patterns(variable_type)
    QP-->>DR: approved code from past runs
    Note over DR: Authority: human > debugger > prior agent

    par Fan-out — asyncio.gather (isolated contexts)
        DR->>C: agent.run(rule.logic, deps)
        activate C
        C->>S: inspect_data(ctx)
        S-->>C: schema + null counts + value ranges (no raw rows)
        C->>S: execute_code(ctx, code)
        S-->>C: aggregate summary (pass/fail, row count)
        C-->>DR: DerivationCode(python_code, approach, null_handling)
        deactivate C
    and
        DR->>QC: agent.run(rule.logic, deps)
        activate QC
        QC->>S: inspect_data(ctx)
        S-->>QC: schema + null counts + value ranges
        QC->>S: execute_code(ctx, code)
        S-->>QC: aggregate summary
        QC-->>DR: DerivationCode(python_code, approach, null_handling)
        deactivate QC
    end

    DR->>V: verify_derivation(coder_code, qc_code, df)
    activate V
    V->>S: execute_derivation(df, coder_code) → Series
    V->>S: execute_derivation(df, qc_code) → Series
    V->>V: compare_results(primary, qc) row-by-row
    V->>V: compute_ast_similarity(coder, qc)
    V-->>DR: VerificationResult(verdict, comparison, ast_similarity)
    deactivate V

    DR->>AT: emit CODER_PROPOSED (approach, code[:200])
    DR->>AT: emit QC_VERDICT (verdict, approach, code[:200])

    alt verdict == MATCH
        DR->>DAG: apply_run_result(APPROVED, code=coder)
        DR->>DR: derived_df[variable] = primary Series
    else verdict == MISMATCH
        DR->>D: agent.run(debug mismatch, coder_code, qc_code, divergent_rows)
        activate D
        D-->>DR: DebugAnalysis(root_cause, correct_implementation, confidence)
        deactivate D
        DR->>AT: emit DEBUGGER_RESOLVED (chose=coder|qc|neither, root_cause)
        alt correct_implementation == coder
            DR->>DAG: apply_run_result(APPROVED, code=coder)
        else correct_implementation == qc
            DR->>DAG: apply_run_result(APPROVED, code=qc)
        else neither
            DR->>DAG: apply_run_result(DEBUG_FAILED)
        end
    else verdict == TOO_SIMILAR
        Note over V: AST similarity > 80% — QC not independent enough
        DR->>QC: agent.run(rule.logic, deps, hint="use a different approach")
        QC-->>DR: DerivationCode (retried)
        Note over DR: Re-verify with new QC output
    end
